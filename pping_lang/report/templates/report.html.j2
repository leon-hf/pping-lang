<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<title>pping-lang report — {{ instance_id }}</title>
<style>
  :root {
    --text: #18181b;
    --muted: #71717a;
    --border: #e4e4e7;
    --surface: #ffffff;
    --bg: #f7f7f8;
    --warning: #f59e0b;
    --critical: #ef4444;
    --info: #3b82f6;
  }
  * { box-sizing: border-box; }
  body {
    margin: 0;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "PingFang SC",
                 "Microsoft YaHei", sans-serif;
    background: var(--bg);
    color: var(--text);
    font-size: 14px;
    line-height: 1.55;
  }
  .container { max-width: 1100px; margin: 0 auto; padding: 32px 24px; }
  header {
    border-bottom: 1px solid var(--border);
    padding-bottom: 16px;
    margin-bottom: 32px;
  }
  header h1 { margin: 0; font-size: 22px; font-weight: 600; }
  header .meta { color: var(--muted); margin-top: 6px; font-size: 13px; }
  h2 {
    font-size: 14px;
    text-transform: uppercase;
    letter-spacing: 0.6px;
    color: var(--muted);
    margin: 36px 0 12px 0;
    border-bottom: 1px solid var(--border);
    padding-bottom: 6px;
  }
  .kpi-row {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
    gap: 12px;
    margin-bottom: 8px;
  }
  .kpi {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 14px 16px;
  }
  .kpi .lbl {
    color: var(--muted);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-bottom: 6px;
  }
  .kpi .val { font-size: 22px; font-weight: 600; font-variant-numeric: tabular-nums; }
  .kpi .val .u { font-size: 13px; font-weight: 400; color: var(--muted); margin-left: 2px; }
  .kpi .val.dim { color: var(--muted); }
  .issue {
    background: var(--surface);
    border: 1px solid var(--border);
    border-left: 4px solid var(--info);
    border-radius: 6px;
    padding: 14px 18px;
    margin-bottom: 10px;
  }
  .issue.warning { border-left-color: var(--warning); }
  .issue.critical { border-left-color: var(--critical); }
  .issue .head { display: flex; justify-content: space-between; align-items: baseline; }
  .issue .rule-id {
    font-family: ui-monospace, Consolas, monospace;
    font-weight: 600;
    font-size: 13px;
  }
  .issue .sev {
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    padding: 2px 6px;
    border-radius: 3px;
    font-weight: 600;
  }
  .issue.warning .sev { background: #fef3c7; color: #92400e; }
  .issue.critical .sev { background: #fee2e2; color: #991b1b; }
  .issue.info .sev { background: #dbeafe; color: #1e40af; }
  .issue .msg { margin: 6px 0; }
  .issue .sug { color: var(--muted); }
  .issue .sug::before { content: "→ "; }
  .issue .meta {
    color: var(--muted);
    font-size: 12px;
    margin-top: 6px;
    font-family: ui-monospace, Consolas, monospace;
  }
  .chart-box {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 12px;
  }
  table {
    width: 100%;
    border-collapse: collapse;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 6px;
    overflow: hidden;
  }
  th, td {
    padding: 8px 12px;
    text-align: left;
    font-size: 13px;
    border-bottom: 1px solid var(--border);
  }
  th {
    background: #fafafa;
    font-weight: 600;
    color: var(--muted);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
  tr:last-child td { border-bottom: none; }
  td code {
    background: #f4f4f5;
    padding: 1px 5px;
    border-radius: 3px;
    font-size: 12px;
    font-family: ui-monospace, Consolas, monospace;
  }
  .suggestion {
    background: #fefce8;
    border-left: 3px solid var(--warning);
    padding: 10px 14px;
    margin-bottom: 8px;
    border-radius: 4px;
  }
  .suggestion .title { font-weight: 600; margin-bottom: 4px; }
  .suggestion .evidence { color: var(--muted); font-size: 12px; margin-bottom: 4px; }
  .suggestion .action { font-size: 13px; }
  .suggestion .action::before { content: "→ "; font-weight: 600; }
  .empty { color: var(--muted); padding: 16px; text-align: center; background: var(--surface);
           border: 1px dashed var(--border); border-radius: 6px; }
  footer {
    margin-top: 48px;
    padding-top: 16px;
    border-top: 1px solid var(--border);
    color: var(--muted);
    font-size: 12px;
    text-align: center;
  }
  details.config-dump {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 12px 16px;
    margin-top: 12px;
  }
  details.config-dump summary {
    cursor: pointer;
    color: var(--muted);
    font-size: 13px;
  }
  details.config-dump pre {
    margin: 12px 0 0 0;
    background: #fafafa;
    padding: 12px;
    border-radius: 4px;
    overflow: auto;
    font-size: 12px;
    font-family: ui-monospace, Consolas, monospace;
  }
</style>
</head>
<body>
<div class="container">

<header>
  <h1>pping-lang report — <code style="font-family: ui-monospace, Consolas, monospace;">{{ instance_id }}</code></h1>
  <div class="meta">
    {{ window_label }} · 生成于 {{ generated_at }} · pping-lang v{{ version }}
  </div>
</header>

<!-- ============== 1. Executive Summary ============== -->
<h2>Executive Summary</h2>
<div class="kpi-row">
  <div class="kpi">
    <div class="lbl">完成请求</div>
    <div class="val">{{ executive.total_requests | default(0) }}</div>
  </div>
  <div class="kpi">
    <div class="lbl">TTFT p50</div>
    <div class="val{% if executive.ttft_p50_ms is none %} dim{% endif %}">
      {% if executive.ttft_p50_ms is not none %}{{ "%.0f" | format(executive.ttft_p50_ms) }}<span class="u">ms</span>{% else %}—{% endif %}
    </div>
  </div>
  <div class="kpi">
    <div class="lbl">TTFT p99</div>
    <div class="val{% if executive.ttft_p99_ms is none %} dim{% endif %}">
      {% if executive.ttft_p99_ms is not none %}{{ "%.0f" | format(executive.ttft_p99_ms) }}<span class="u">ms</span>{% else %}—{% endif %}
    </div>
  </div>
  <div class="kpi">
    <div class="lbl">GPU 利用率 (avg)</div>
    <div class="val{% if executive.gpu_util_avg_pct is none %} dim{% endif %}">
      {% if executive.gpu_util_avg_pct is not none %}{{ "%.0f" | format(executive.gpu_util_avg_pct) }}<span class="u">%</span>{% else %}—{% endif %}
    </div>
  </div>
  <div class="kpi">
    <div class="lbl">MFU (avg)</div>
    <div class="val{% if executive.mfu_avg_pct is none %} dim{% endif %}">
      {% if executive.mfu_avg_pct is not none %}{{ "%.0f" | format(executive.mfu_avg_pct) }}<span class="u">%</span>{% else %}—{% endif %}
    </div>
  </div>
  <div class="kpi">
    <div class="lbl">Padding (avg)</div>
    <div class="val{% if executive.padding_ratio_avg_pct is none %} dim{% endif %}">
      {% if executive.padding_ratio_avg_pct is not none %}{{ "%.0f" | format(executive.padding_ratio_avg_pct) }}<span class="u">%</span>{% else %}—{% endif %}
    </div>
  </div>
  <div class="kpi">
    <div class="lbl">触发诊断数</div>
    <div class="val">{{ executive.total_diagnoses }}</div>
  </div>
</div>

<!-- ============== 2. 关键问题 ============== -->
<h2>关键问题</h2>
{% if diagnoses %}
  {% for d in diagnoses %}
    <div class="issue {{ d.severity }}">
      <div class="head">
        <span class="rule-id">{{ d.rule_id }}</span>
        <span class="sev">{{ d.severity }}</span>
      </div>
      <div class="msg">{{ d.message }}</div>
      <div class="sug">{{ d.suggestion }}</div>
      <div class="meta">触发 {{ d.fire_count }} 次 · 阈值 {{ "%.3g" | format(d.threshold) }} · 平均触发值 {{ "%.3g" | format(d.avg_value) }}</div>
    </div>
  {% endfor %}
{% else %}
  <div class="empty">窗口内无诊断触发 — 系统运行正常</div>
{% endif %}

<!-- ============== 3. 趋势分析 ============== -->
<h2>趋势</h2>
{% if has_trend_data %}
  <div class="chart-box">{{ trend_html | safe }}</div>
{% else %}
  <div class="empty">窗口内无指标数据</div>
{% endif %}

<!-- ============== 4. 配置审计 ============== -->
<h2>配置审计</h2>
{% if audit_suggestions %}
  {% for s in audit_suggestions %}
    <div class="suggestion">
      <div class="title">{{ s.title }}</div>
      <div class="evidence">{{ s.evidence }}</div>
      <div class="action">{{ s.action }}</div>
    </div>
  {% endfor %}
{% else %}
  <div class="empty">无显著可优化项</div>
{% endif %}
{% if config_data %}
  <details class="config-dump">
    <summary>vLLM 配置快照（点击展开）</summary>
    <pre>{{ config_data | tojson(indent=2) }}</pre>
  </details>
{% endif %}

<!-- ============== 5. Roofline ============== -->
<h2>Roofline</h2>
{% if has_roof_data %}
  <div class="chart-box">{{ roof_html | safe }}</div>
{% else %}
  <div class="empty">无 perf_stats 数据（需 vLLM 启用 perf 收集）</div>
{% endif %}

<!-- ============== 6. 触发规则汇总 ============== -->
<h2>规则触发汇总</h2>
{% if rules_summary %}
  <table>
    <thead>
      <tr><th>规则</th><th>severity</th><th>触发次数</th></tr>
    </thead>
    <tbody>
      {% for r in rules_summary %}
        <tr>
          <td><code>{{ r.rule_id }}</code></td>
          <td>{{ r.severity }}</td>
          <td>{{ r.fire_count }}</td>
        </tr>
      {% endfor %}
    </tbody>
  </table>
{% else %}
  <div class="empty">无规则触发记录</div>
{% endif %}

<footer>
  Generated by pping-lang v{{ version }} · plotly 模式: {{ plotly_mode }}
</footer>

</div>
</body>
</html>
